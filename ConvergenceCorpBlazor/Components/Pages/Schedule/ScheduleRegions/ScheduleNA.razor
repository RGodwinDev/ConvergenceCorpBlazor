    struct BigRun{
        TimeZoneInfo TimeZoneInfo = TimeZoneInfo.Utc;
        String GuildName = "Default Guild";
        String CommName = "Default Commander";
        int Day = 0; //0 = monday
        TimeSpan Time = new TimeSpan(0, 0, 0);

        public BigRun(TimeZoneInfo timezone, String name, int d, TimeSpan t)
        {
            this.TimeZoneInfo = timezone;
            this.CommName = name;
            this.Day = d;
            this.Time = t;
        }
    }

    struct Guild
    {
        String GuildName;
        List<BigRun> runList = [];

        public Guild(string gname)
        {
            this.GuildName = gname;
        }
        public void AddRun(BigRun bigRun)
        {
            runList.Add(bigRun);
        }
    }

    List<Guild> GuildList = [
        new Guild("Convergence Corp[CC]")
    ];
    
    
    //GuildList[0].AddRun(new BigRun(TimeZoneInfo.FindSystemTimeZoneById("America/Central"), "SunMatrix", 1, new TimeSpan(0,0,0)));



    [Parameter]
    public TimeZoneInfo tzone { get; set; } = TimeZoneInfo.Utc;

    
}

<script>

    var times = document.getElementsByClassName("NAtime");
    for(var time of times){
        //get the date
        let d = new Date(time.innerText);
        //convert the time
        time.innerText = d.toLocaleString([], {
            hour:'numeric',
            minute:'2-digit'
        });

        //get the day
        var listname = '#NA'+ d.toLocaleString('en-US',{weekday:'long'});
        //move to the correct day
        document.querySelector(listname).append(time.parentElement);
    }


    var anytimes = document.getElementsByClassName("NAAnytime");
    for(var any of anytimes){
        //convert the time
        any.innerText = new Date(any.innerText).toLocaleString([], {
            hour:'numeric',
            minute:'2-digit'
        });
    }
</script>
