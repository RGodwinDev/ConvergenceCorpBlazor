@code{
    DateTimeOffset chivalrytime =   new DateTimeOffset(2025,11,10,15,00,00,TimeSpan.FromHours(1));
    DateTimeOffset cutetimeWed =    new DateTimeOffset(2025,11,12,18,00,00,TimeSpan.FromHours(1));
    DateTimeOffset cutetimeThur =   new DateTimeOffset(2025,11,13,18,00,00,TimeSpan.FromHours(1));
    //DateTimeOffset skeintime =      new DateTimeOffset(2025,11,08,19,30,00,TimeSpan.FromHours(0));
    DateTimeOffset Septemtime =     new DateTimeOffset(2026,05,30,15,00,00, TimeSpan.FromHours(3));
}
<script>
    var times = document.getElementsByClassName("EUtime");
    for(var time of times){
        //get the date
        let d = new Date(time.innerText);
        //convert the time
        time.innerText = d.toLocaleString([], {
            hour:'numeric',
            minute:'2-digit'
        });

        //get the day
        var listname = '#EU'+ d.toLocaleString('en-US',{weekday:'long'});
        //move to the correct day
        document.querySelector(listname).append(time.parentElement);
    }
    var anytimes = document.getElementsByClassName("EUAnytime");
    for(var any of anytimes){
        //convert the time
        any.innerText = new Date(any.innerText).toLocaleString([], {
            hour:'numeric',
            minute:'2-digit'
        });
    }


</script>
