</section>
<script>
    function opencloseachieves(classtoopenclose){
        var obj = document.getElementsByClassName(classtoopenclose);
        for(i = 0; i < obj.length; ++i){
            if(obj[i].style.display == "block"){
                obj[i].style.display = "none";
            }
            else{
                obj[i].style.display = "block";
            }
        }
    }
</script>