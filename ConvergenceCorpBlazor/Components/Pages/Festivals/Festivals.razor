@page "/Festivals"
<HeadContent>
    <meta name="description" content="Guild Wars 2 festival guides">
    <link rel="canonical" href="https://convergencecorp.net/Festivals" />
    <meta property="og:title" content="Festivals! | Convergence Corp!" />
    
    <meta property="og:url" content="https://convergencecorp.net/Festivals" />
    <meta property="og:image" content="https://convergencecorp.net/favicon/android-chrome-512x512.png" />
